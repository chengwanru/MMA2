+def _classify_alfred_invalid_reason(message):
+    """Map Thor error message to a coarse reason bucket for JSONL logging."""
+    if not message:
+        return "unknown"
+    m = message.lower()
+    if "teleportfull" in m and "missing the following arguments" in m:
+        return "missing_action_args"
+    if "teleportfull" in m:
+        return "teleport_failure"
+    if re.search(r"cannot\s+find\s+.+\s+to\s+pick\s+up", m):
+        return "not_found_before_pickup"
+    if "find the object before picking up" in m:
+        return "not_found_before_pickup"
+    if "may not exist in this scene" in m:
+        return "object_not_in_scene"
+    if "not visible" in m:
+        return "not_visible"
+    if "too far" in m or "out of reach" in m:
+        return "not_reachable"
+    if "cannot" in m and "open" in m:
+        return "cannot_open"
+    if "because it is in" in m or "does not contain" in m:
+        return "container_or_location"
+    return "other"
 
+
+def _append_invalid_jsonl(log_path, record):
+    if not log_path:
+        return
+    d = os.path.dirname(log_path)
+    if d:
+        os.makedirs(d, exist_ok=True)
+    with open(log_path, "a", encoding="utf-8") as f:
+        f.write(json.dumps(record, ensure_ascii=False))
+        f.write("\n")
+
