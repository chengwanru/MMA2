# Copy to openeqa_judge_smoke.env and fill in keys (do NOT commit the .env file).
#
#   cp openeqa_judge_smoke.env.example openeqa_judge_smoke.env
#   $EDITOR openeqa_judge_smoke.env
#   set -a && source openeqa_judge_smoke.env && set +a
#
# Recommended for smoke / internal iteration: OpenRouter free models.
# Sign up: https://openrouter.ai/keys  (free tier ~50 requests/day without top-up)

# --- OpenRouter (recommended smoke judge) ---
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY
# Fixed free slug (more stable than openrouter/free random routing).
OPENEQA_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Alternatives if rate-limited or 404:
# OPENEQA_OPENROUTER_MODEL=openrouter/free
# OPENEQA_OPENROUTER_MODEL=google/gemma-3-27b-it:free

# --- Groq (optional backup; https://console.groq.com/keys) ---
# GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_KEY
# OPENEQA_GROQ_MODEL=llama-3.3-70b-versatile

# --- Official OpenAI (final experiments only) ---
# OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY
# OPENEQA_JUDGE_MODEL=gpt-4-1106-preview

# Throttle free APIs (seconds between requests; OpenRouter free ~20 RPM)
OPENEQA_JUDGE_SLEEP_SEC=1.0
